{
  "log_level": "LOG_LEVEL_DEBUG",
  "dbus": {
    "enabled": true,
    "connect_timeout": "20s",
    "connect_interval": "1s",
    "notifications": {
      "enabled": true
    },
    "systray": {
      "enabled": true
    },
    "shortcuts": {
      "enabled": true
    },
    "brightness": {
      "enabled": true,
      "adjust_step_percent": 5,
      "min_brightness": 1,
      "enable_logind": true,
      "hud_notifications": false
    },
    "idle_inhibitor": {
      "enabled": true
    },
    "media_player": {
      "enabled": true
    },
    "power": {
      "enabled": true,
      "low_percent": 10,
      "critical_percent": 5,
      "low_command": "",
      "critical_command": "",
      "hud_notifications": false
    }
  },
  "audio": {
    "enabled": true,
    "volume_step_percent": 5,
    "volume_exceed_maximum": false,
    "hud_notifications": false
  },
  "icon_overrides": [
    {
      "window_class": "missioncenter",
      "icon": "htop"
    },
    {
      "window_class": "AyuGram Desktop",
      "icon": "telegram"
    }
  ],
  "launch_wrapper": ["sh", "-c"],
  "panels": [
    {
      "id": "panel0",
      "edge": "EDGE_LEFT",
      "size": 64,
      "handle_enabled": false,
      "handle_reveal_mode": "PANEL_HANDLE_REVEAL_MODE_HOVER",
      "auto_hide_delay": "1s",
      "monitor": "",
      "modules": [
        {
          "taskbar": {
            "icon_size": 44,
            "active_workspace_only": false,
            "active_monitor_only": true,
            "group_tasks": true,
            "hide_indicators": false,
            "expand": true,
            "max_size": 0,
            "pinned": ["discord", "AyuGram Desktop", "thunderbird", "zen"],
            "preview_width": 256
          }
        },
        {
          "pager": {
            "icon_size": 15,
            "active_monitor_only": true,
            "scroll_wrap_workspaces": true,
            "scroll_include_inactive": true,
            "enable_workspace_names": false,
            "pinned": [1, 2, 3],
            "ignore_windows": [],
            "preview_width": 256,
            "follow_window_on_move": false,
            "show_hidden": false
          }
        },
        {
          "notifications": {
            "icon_size": 28,
            "notification_icon_size": 48,
            "default_timeout": "7s",
            "position": "POSITION_TOP_RIGHT",
            "margin": 24,
            "persistent": []
          }
        },
        {
          "systray": {
            "icon_size": 24,
            "menu_icon_size": 22,
            "auto_hide_statuses": [
              "STATUS_UNSPECIFIED",
              "STATUS_PASSIVE",
              "STATUS_ACTIVE"
            ],
            "auto_hide_delay": "4s",
            "pinned": [],
            "modules": []
          }
        },
        {
          "idle_inhibitor": {
            "icon_size": 19,
            "icon_symbolic": true,
            "default_target": 1
          }
        },
        {
          "media_player": {
            "icon_size": 19,
            "icon_symbolic": true
          }
        },
        {
          "audio": {
            "icon_size": 25,
            "icon_symbolic": true,
            "command_mixer": "pavucontrol",
            "enable_source": false
          }
        },
        {
          "power": {
            "icon_size": 24,
            "icon_symbolic": true
          }
        },
        {
          "clock": {
            "time_format": "15\n04",
            "date_format": "",
            "tooltip_time_format": "15:04",
            "tooltip_date_format": "Mon, 02 Jan 2006 MST",
            "additional_regions": []
          }
        },
        {
          "session": {
            "icon_size": 25,
            "icon_symbolic": true,
            "overlay_icon_size": 96,
            "overlay_icon_symbolic": true,
            "command_logout": "loginctl terminate-session $XDG_SESSION_ID",
            "command_reboot": "reboot",
            "command_suspend": "suspend",
            "command_shutdown": "poweroff"
          }
        }
      ]
    }
  ]
}
